@startuml abrirTareas-analisis
skinparam linetype polyline

actor Usuario
package abrirTareas as "abrirTareas()" {
    rectangle #629EF9 ListarTareasView
    rectangle #b5bd68 TareasController
    rectangle #F2AC4E TareaRepository
    rectangle #F2AC4E Tarea
    rectangle #F2AC4E Grupo
}
rectangle #CDEBA5 ":Sistema Disponible" as SistemaDisponible

SistemaDisponible -r-> ListarTareasView: 1: abrirTareas()

ListarTareasView -d-> TareasController: 2: listarTareas(grupo)

TareasController --> TareaRepository: 3: obtenerTareasPorGrupo(grupo)

TareaRepository -- Tarea
TareaRepository -- Grupo

ListarTareasView -r-> SistemaDisponible: 4: sistemaDisponible(usuario)

@enduml

@startuml abrirGrupos-analisis
skinparam linetype polyline

actor Usuario
package abrirGrupos as "abrirGrupos()" {
    rectangle #629EF9 ListarGruposView
    rectangle #b5bd68 GruposController
    rectangle #F2AC4E GrupoRepository
    rectangle #F2AC4E Grupo
}
rectangle #CDEBA5 ":Sistema Disponible" as SistemaDisponible

SistemaDisponible -r-> ListarGruposView: 1: abrirGrupos()

ListarGruposView -d-> GruposController: 2: listarGrupos(usuario)

GruposController --> GrupoRepository: 3: obtenerGruposPorUsuario(usuario)

GrupoRepository -- Grupo

ListarGruposView -r-> SistemaDisponible: 4: sistemaDisponible(usuario)

@enduml
